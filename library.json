{
  "name": "BMx280PIO_RP2040",
  "version": "1.1.0",
  "description": "BMP280/BME280 sensor driver for Raspberry Pi Pico (RP2040). Uses TwoWirePIO_RP2040 (WirePIO) for PIO+DMA I2C on any GPIO pins. Also supports hardware I2C (Wire). Auto-detects BMP280 vs BME280.",
  "keywords": [
    "BMP280",
    "BME280",
    "RP2040",
    "PIO",
    "I2C",
    "sensor",
    "temperature",
    "humidity",
    "pressure",
    "Raspberry Pi Pico",
    "PlatformIO"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/angeloINTJ/BMx280PIO_RP2040.git"
  },
  "authors": [
    {
      "name": "Ângelo Moisés Alves",
      "url": "https://github.com/angeloINTJ",
      "maintainer": "Ângelo Moisés Alves"
    }
  ],
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": "raspberrypi",
  "headers": [
    "BMx280PIO_RP2040.h"
  ],
  "examples": [
    {
      "name": "Basic Reading",
      "base": "examples/basic_reading",
      "files": ["basic_reading.ino"]
    },
    {
      "name": "Forced Mode",
      "base": "examples/forced_mode",
      "files": ["forced_mode.ino"]
    },
    {
      "name": "PIO+DMA Auto-Scan",
      "base": "examples/auto_scan",
      "files": ["auto_scan.ino"]
    },
    {
      "name": "Multi Sensor",
      "base": "examples/multi_sensor",
      "files": ["multi_sensor.ino"]
    }
  ],
  "dependencies": {
    "https://github.com/angeloINTJ/TwoWirePIO_RP2040.git": "^1.1.0"
  }
}
