{
  "name": "BMx280PIO_RP2040",
  "version": "1.0.0",
  "description": "BMP280/BME280 sensor driver for Raspberry Pi Pico (RP2040). Supports both PIO-based I2C and hardware I2C (Wire). Auto-detects BMP280 vs BME280.",
  "keywords": [
    "BMP280",
    "BME280",
    "RP2040",
    "PIO",
    "I2C",
    "sensor",
    "temperature",
    "humidity",
    "pressure",
    "Raspberry Pi Pico",
    "PlatformIO"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/angeloINTJ/BMx280PIO_RP2040.git"
  },
  "authors": [
    {
      "name": "angeloINTJ",
      "url": "https://github.com/angeloINTJ"
    }
  ],
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": "raspberrypi",
  "headers": [
    "BMx280PIO_RP2040.h",
    "PIO_I2C.h"
  ],
  "examples": [
    {
      "name": "Basic Reading",
      "base": "examples/basic_reading",
      "files": ["basic_reading.ino"]
    },
    {
      "name": "Forced Mode",
      "base": "examples/forced_mode",
      "files": ["forced_mode.ino"]
    },
    {
      "name": "PIO+DMA Auto-Scan",
      "base": "examples/auto_scan",
      "files": ["auto_scan.ino"]
    },
    {
      "name": "PIO+DMA Hybrid Test",
      "base": "examples/pio_dma_hybrid",
      "files": ["pio_dma_hybrid.ino"]
    }
  ],
  "dependencies": {
    "earlephilhower/arduino-pico": "^4.0.0"
  }
}
