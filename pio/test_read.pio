.program test_read
.side_set 1 opt
    pull block          side 1
    ; Release SDA
    set pindirs, 0      side 0
    set y, 7            side 0
read_loop:
    nop                 side 1 [3]
    in pins, 1          side 1
    nop                 side 0 [3]
    jmp y--, read_loop  side 0
    ; Push the byte
    push noblock        side 0
.wrap
